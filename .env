COMPOSE_PROJECT_NAME=flight-delay-pipeline

# Rentang tahun dataset yang akan diproses
DATA_START_YEAR=2024
DATA_END_YEAR=2025

# Koneksi ClickHouse Lokal (Saat Proses Spark & Streaming Berjalan)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=flight_delay
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

===== KONEKSI AWS EC2 (Gunakan ini NANTI jika ingin script/tools lokal menembak langsung ke AWS) =====
# CLICKHOUSE_HOST=13.215.79.3
# CLICKHOUSE_HTTP_PORT=8123
# CLICKHOUSE_NATIVE_PORT=9000
# CLICKHOUSE_DB=flight_delay
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=rahasia123

# Konfigurasi Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=ontime.raw
KAFKA_TOPIC_PARTITIONS=3
KAFKA_RETENTION_MS=604800000

# Perilaku Kafka producer saat streaming
STREAM_BATCH_SIZE=1000
STREAM_SLEEP_SECONDS=0.2

# Grafana admin credentials (ganti saat deploy ke production)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Mode penyimpanan: "local" atau "s3"
STORAGE_MODE=local
S3_BUCKET=
AWS_REGION=
